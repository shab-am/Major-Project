# MariaDB Database Configuration
DB_USER=hydro_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hydroponics_db

# Serial Port Configuration (for hardware data collection)
# Windows: COM3, COM4, etc.
# Linux: /dev/ttyUSB0, /dev/ttyACM0, etc.
# macOS: /dev/cu.usbmodem*, /dev/tty.usbmodem*
SERIAL_PORT=COM3
BAUD_RATE=9600

